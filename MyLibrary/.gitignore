!**/.vscode/tasks.json
!**/.vscode/launch.json
!**/.vscode/extensions.json
!**/.vscode/mcp.json
**/.history/*

# IntelliJ IDEA
**/.idea/
*.iws
*.iml
*.ipr

# Eclipse / STS / NetBeans antigos
**/.apt_generated/
.classpath
.factorypath
.project
**/.settings/
.springBeans
.sts4-cache/

